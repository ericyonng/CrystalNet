# MongoDB 分片集群节点列表
# 格式: 类型 IP地址/域名 端口
#
# 支持的类型:
#   config  - 配置服务器节点(必须3个节点组成复制集)
#   shard1  - 分片1的数据节点(至少1个节点, 建议3个节点组成复制集)
#   shard2  - 分片2的数据节点(至少1个节点, 建议3个节点组成复制集)
#   shardN  - 分片N的数据节点(shard后跟数字, 数字递增)
#   mongos  - 路由节点(至少1个)
#
# 注意:
#   1. 同一类型的多个节点组成一个复制集, 节点数量由同类型行数决定
#   2. 以#开头的行和空行会被跳过
#   3. 每个分片(shard1, shard2, ...)是独立的复制集
#
# 示例: 2个分片, 每个分片3节点, 3个config, 2个mongos

# config配置服务器 (3节点复制集)
config 192.168.1.1 27010
config 192.168.1.2 27010
config 192.168.1.3 27010

# shard1 分片1 (3节点复制集)
shard1 192.168.1.1 27011
shard1 192.168.1.2 27011
shard1 192.168.1.3 27011

# shard2 分片2 (3节点复制集)
shard2 192.168.1.4 27011
shard2 192.168.1.5 27011
shard2 192.168.1.6 27011

# mongos路由 (2节点)
mongos 192.168.1.1 27017
mongos 192.168.1.2 27017
